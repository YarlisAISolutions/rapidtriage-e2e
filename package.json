{
  "name": "rapidtriage-e2e",
  "version": "0.1.0",
  "description": "Public end-to-end validation suite for rapidtriage.me",
  "private": false,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:auth": "playwright test --project=auth",
    "test:api": "playwright test --project=api",
    "test:marketing": "playwright test --project=marketing",
    "test:billing": "playwright test --project=billing",
    "test:triage": "playwright test --project=triage",
    "test:pages": "playwright test --project=pages",
    "report": "playwright show-report",
    "install-browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
